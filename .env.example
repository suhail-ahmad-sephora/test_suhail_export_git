# Nova BYOA — Required environment variables
# Copy this file to .env and fill in the values.

# The agent ID that Nova uses to route requests to this container.
# Must match the ID you register in the Nova BYOA Registry.
NOVA_AGENT_ID=a062f865-03a9-4a4c-95dd-564985079b00

# LiteLLM proxy URL (used by the agent to call LLMs and vector stores)
LITELLM_BASE_URL=https://litellm.your-domain.com

# LiteLLM API key (your personal key)
LITELLM_API_KEY=sk-litellm-your-key-here

# LLM model to use (default: gpt-4.1-20250414)
NOVA_MODEL=gpt-4.1-20250414
